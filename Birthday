<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Happy Birthday Saikat Sir</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Great+Vibes&family=Poppins:wght@300;400;600&display=swap');

        body, html {
            margin: 0;
            padding: 0;
            width: 100%;
            height: 100%;
            background: radial-gradient(circle, #121420 0%, #06070a 100%);
            font-family: 'Poppins', sans-serif;
            overflow: hidden;
            display: flex;
            justify-content: center;
            align-items: center;
            color: #ffffff;
        }

        /* Auto-cropped Coaching Logo at Top Corner */
        .uttaron-logo {
            position: absolute;
            top: 25px;
            left: 25px;
            width: 85px;
            height: 85px;
            /* Using your specific image file */
            background-image: url('1000134435.jpg');
            background-size: 380%; /* Zooms in to get only the logo */
            background-position: center 3%; /* Focuses on the top yellow part */
            background-repeat: no-repeat;
            background-color: #ffffff;
            border-radius: 50%;
            z-index: 100;
            box-shadow: 0 0 15px rgba(251, 197, 49, 0.4);
            border: 2px solid #fbc531;
            animation: slideInLogo 1.5s ease-out;
        }

        .card {
            text-align: center;
            z-index: 10;
            padding: 40px 50px;
            background: rgba(255, 255, 255, 0.05);
            border-radius: 20px;
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.5);
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            transform: translateY(50px) scale(0.9);
            opacity: 0;
            animation: slideUpFade 1.5s cubic-bezier(0.23, 1, 0.32, 1) forwards;
        }

        .date {
            font-size: 1.1rem;
            color: #e1b12c;
            letter-spacing: 3px;
            margin-bottom: 20px;
            font-weight: 400;
            text-transform: uppercase;
        }

        /* Profile Image Styles */
        .profile-container {
            width: 130px;
            height: 130px;
            margin: 0 auto 20px auto;
            border-radius: 50%;
            padding: 4px;
            background: linear-gradient(45deg, #fbc531, #e1b12c, #fbc531);
            background-size: 200% 200%;
            box-shadow: 0 0 25px rgba(251, 197, 49, 0.5);
            animation: gradientMove 3s ease infinite;
        }

        .profile-img {
            width: 100%;
            height: 100%;
            border-radius: 50%;
            object-fit: cover;
            border: 4px solid #121420;
            box-sizing: border-box;
            background-color: #2f3640;
        }

        h1 {
            font-family: 'Great Vibes', cursive;
            font-size: 4.5rem;
            margin: 0;
            color: #fbc531;
            text-shadow: 0 0 20px rgba(251, 197, 49, 0.4);
            animation: pulseGlow 2.5s infinite alternate;
        }

        .name {
            font-size: 1.8rem;
            margin-top: 5px;
            font-weight: 600;
            letter-spacing: 2px;
            color: #f5f6fa;
        }

        .coaching {
            font-size: 1.1rem;
            color: #7f8fa6;
            margin-top: 5px;
            margin-bottom: 30px;
            font-weight: 300;
        }

        .sender {
            margin-top: 20px;
            font-size: 0.85rem;
            color: #718093;
            font-weight: 300;
            letter-spacing: 1px;
            border-top: 1px solid rgba(255, 255, 255, 0.1);
            padding-top: 15px;
        }

        .sender span {
            color: #e1b12c;
            font-weight: 400;
            font-size: 1rem;
        }

        @keyframes slideInLogo {
            from { transform: translateX(-50px); opacity: 0; }
            to { transform: translateX(0); opacity: 1; }
        }

        @keyframes slideUpFade {
            to {
                transform: translateY(0) scale(1);
                opacity: 1;
            }
        }

        @keyframes pulseGlow {
            0% { text-shadow: 0 0 10px rgba(251, 197, 49, 0.3); transform: scale(1); }
            100% { text-shadow: 0 0 30px rgba(251, 197, 49, 0.8); transform: scale(1.02); }
        }

        @keyframes gradientMove {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        #confetti-canvas {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 1;
            pointer-events: none;
        }
    </style>
</head>
<body>

    <!-- CSS will auto-crop this into the logo circle -->
    <div class="uttaron-logo" title="Uttaron"></div>

    <canvas id="confetti-canvas"></canvas>

    <div class="card">
        <div class="date">13 May 2026</div>
        
        <!-- Sir's Photo Container -->
        <div class="profile-container">
            <img src="sir-photo.jpg" alt="Saikat Sir" class="profile-img">
        </div>

        <h1>Happy Birthday</h1>
        <div class="name">Saikat Bera Sir</div>
        <div class="coaching">H.O.I, Uttaron Coaching</div>
        
        <div class="sender">Best wishes from,<br><span>Sashanka Nandi</span></div>
    </div>

    <!-- Realistic Confetti Javascript Library -->
    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>
    <script>
        window.onload = function() {
            var duration = 6 * 1000;
            var animationEnd = Date.now() + duration;
            var defaults = { startVelocity: 30, spread: 360, ticks: 60, zIndex: 0 };

            function randomInRange(min, max) {
                return Math.random() * (max - min) + min;
            }

            var interval = setInterval(function() {
                var timeLeft = animationEnd - Date.now();

                if (timeLeft <= 0) {
                    return clearInterval(interval);
                }

                var particleCount = 50 * (timeLeft / duration);
                
                confetti(Object.assign({}, defaults, { 
                    particleCount, 
                    origin: { x: randomInRange(0.1, 0.3), y: Math.random() - 0.2 } 
                }));
                confetti(Object.assign({}, defaults, { 
                    particleCount, 
                    origin: { x: randomInRange(0.7, 0.9), y: Math.random() - 0.2 } 
                }));
            }, 250);
            
            setTimeout(() => {
                confetti({
                    particleCount: 150,
                    spread: 100,
                    origin: { y: 0.6 }
                });
            }, 500);
        };
    </script>
</body>
</html>
