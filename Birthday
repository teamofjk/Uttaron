<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Happy Birthday Saikat Sir</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Great+Vibes&family=Poppins:wght@300;400;600;700&display=swap');

        body, html {
            margin: 0;
            padding: 0;
            width: 100%;
            height: 100%;
            background: radial-gradient(circle at center, #181c2e 0%, #0c0e18 100%);
            font-family: 'Poppins', sans-serif;
            overflow: hidden;
            display: flex;
            justify-content: center;
            align-items: center;
            color: #ffffff;
        }

        /* Main Card Structure */
        .birthday-card {
            text-align: center;
            z-index: 10;
            padding: 60px 80px;
            background: rgba(255, 255, 255, 0.04);
            border-radius: 25px;
            box-shadow: 0 15px 50px rgba(0, 0, 0, 0.7);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            transform: translateY(50px) scale(0.9);
            opacity: 0;
            animation: slideUpFadePremium 1.5s cubic-bezier(0.23, 1, 0.32, 1) forwards;
        }

        .date-box {
            display: inline-block;
            padding: 8px 25px;
            background: rgba(225, 177, 44, 0.1);
            border: 1px solid rgba(225, 177, 44, 0.3);
            border-radius: 30px;
            font-size: 1.1rem;
            color: #e1b12c;
            letter-spacing: 4px;
            margin-bottom: 30px;
            font-weight: 400;
            text-transform: uppercase;
        }

        h1 {
            font-family: 'Great Vibes', cursive;
            font-size: 6.5rem;
            margin: 0;
            color: #fbc531;
            text-shadow: 0 0 25px rgba(251, 197, 49, 0.5);
            animation: pulseTextGlow 2s infinite alternate;
        }

        .name-and-title {
            margin-top: 15px;
            letter-spacing: 2.5px;
        }

        .sir-name {
            font-size: 2.5rem;
            font-weight: 700;
            color: #f5f6fa;
            text-transform: uppercase;
            letter-spacing: 5px;
            margin-bottom: 10px;
        }

        .coaching-title {
            font-size: 1.3rem;
            color: #aeb9cc;
            font-weight: 300;
            margin-bottom: 40px;
            letter-spacing: 3px;
        }

        .coaching-graphic {
            width: 40px;
            height: 40px;
            margin: 0 auto 40px auto;
            opacity: 0.8;
            animation: rotateSlow 10s linear infinite;
        }

        .from-section {
            margin-top: 20px;
            font-size: 1rem;
            color: #8c98ad;
            font-weight: 300;
            letter-spacing: 1.5px;
            border-top: 1px solid rgba(255, 255, 255, 0.12);
            padding-top: 25px;
        }

        .from-name {
            color: #e1b12c;
            font-weight: 600;
            font-size: 1.2rem;
            display: block;
            margin-top: 8px;
        }

        @keyframes slideUpFadePremium {
            to {
                transform: translateY(0) scale(1);
                opacity: 1;
            }
        }

        @keyframes pulseTextGlow {
            0% { text-shadow: 0 0 10px rgba(251, 197, 49, 0.3); }
            100% { text-shadow: 0 0 35px rgba(251, 197, 49, 0.9); }
        }

        @keyframes rotateSlow {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }

        #realistic-confetti {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 1;
            pointer-events: none;
        }
    </style>
</head>
<body>

    <canvas id="realistic-confetti"></canvas>

    <div class="birthday-card">
        <div class="date-box">13 MAY 2026</div>
        
        <h1>Happy Birthday</h1>
        
        <div class="name-and-title">
            <div class="sir-name">SAIKAT BERA</div>
            <div class="coaching-title">UTTARON COACHING</div>
        </div>

        <svg class="coaching-graphic" viewBox="0 0 100 100">
            <polygon points="50,10 61,39 92,39 67,58 76,88 50,70 24,88 33,58 8,39 39,39" fill="none" stroke="#fbc531" stroke-width="4"/>
            <circle cx="50" cy="50" r="15" fill="#fbc531" opacity="0.5"/>
        </svg>

        <div class="from-section">Best wishes from,<br><span class="from-name">SASHANKA NANDI</span></div>
    </div>

    <script>
        window.onload = function() {
            const canvas = document.getElementById('realistic-confetti');
            const ctx = canvas.getContext('2d');
            let particles = [];
            let particleCount = 150;
            let initialBurstDone = false;

            function resize() {
                canvas.width = window.innerWidth;
                canvas.height = window.innerHeight;
            }
            window.addEventListener('resize', resize);
            resize();

            const colors = ['#fbc531', '#e1b12c', '#ffffff', '#ff4d4d', '#32ff7e', '#18dcff', '#ff9ff3'];

            function createParticle() {
                const x = Math.random() * canvas.width;
                const y = Math.random() * -canvas.height;
                const size = Math.random() * 8 + 6;
                const color = colors[Math.floor(Math.random() * colors.length)];
                const vx = (Math.random() - 0.5) * 4;
                const vy = Math.random() * 5 + 3;
                const angle = Math.random() * Math.PI * 2;
                const spin = Math.random() * 0.1 - 0.05;

                return { x, y, size, color, vx, vy, angle, spin };
            }

            function initialBurst() {
                for (let i = 0; i < 80; i++) {
                    const x = canvas.width / 2;
                    const y = canvas.height / 2;
                    const size = Math.random() * 10 + 8;
                    const color = colors[Math.floor(Math.random() * colors.length)];
                    const vx = (Math.random() - 0.5) * 25;
                    const vy = (Math.random() - 0.5) * 25;
                    const angle = Math.random() * Math.PI * 2;
                    const spin = Math.random() * 0.1 - 0.05;

                    particles.push({ x, y, size, color, vx, vy, angle, spin });
                }
                initialBurstDone = true;
            }

            function update() {
                ctx.clearRect(0, 0, canvas.width, canvas.height);

                if (!initialBurstDone) {
                    setTimeout(initialBurst, 300); 
                    initialBurstDone = true; 
                }

                if (particles.length < particleCount) {
                    particles.push(createParticle());
                }

                particles.forEach((p, index) => {
                    p.x += p.vx;
                    p.y += p.vy;
                    p.angle += p.spin;

                    if (initialBurstDone && p.vy < 0) { 
                      p.vy *= 0.98; 
                    }

                    ctx.save();
                    ctx.translate(p.x, p.y);
                    ctx.rotate(p.angle);
                    ctx.fillStyle = p.color;
                    ctx.fillRect(-p.size / 2, -p.size / 2, p.size, p.size);
                    ctx.restore();

                    if (p.y > canvas.height + p.size) {
                        particles[index] = createParticle();
                    }
                });

                requestAnimationFrame(update);
            }

            update();
        };
    </script>
</body>
</html>
