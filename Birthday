
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Happy Birthday Soumili</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Dancing+Script:wght@700&family=Poppins:wght@300;400;600&display=swap');

        body, html {
            margin: 0;
            padding: 0;
            height: 100%;
            width: 100%;
            overflow: hidden;
            font-family: 'Poppins', sans-serif;
            background: #ffe6f2;
        }

        /* Floating Hearts Animation */
        .heart {
            position: absolute;
            color: #ff4d94;
            font-size: 20px;
            pointer-events: none;
            animation: float 5s linear infinite;
            z-index: 1;
        }

        @keyframes float {
            0% { transform: translateY(100vh) rotate(0deg); opacity: 1; }
            100% { transform: translateY(-10vh) rotate(360deg); opacity: 0; }
        }

        .page {
            position: absolute;
            width: 100%;
            height: 100%;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            transition: opacity 1s ease-in-out, transform 1s ease-in-out;
            opacity: 0;
            visibility: hidden;
            z-index: 5;
        }

        .active {
            opacity: 1;
            visibility: visible;
        }

        h1 {
            font-family: 'Dancing Script', cursive;
            font-size: 4rem;
            color: #d63384;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.1);
            animation: bounce 2s infinite;
        }

        .gift-container {
            font-size: 5rem;
            display: flex;
            gap: 20px;
            margin-top: 20px;
        }

        .wish-text {
            max-width: 600px;
            padding: 20px;
            font-size: 1.5rem;
            color: #444;
            background: rgba(255, 255, 255, 0.6);
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        }

        .footer {
            position: absolute;
            bottom: 20px;
            width: 100%;
            text-align: center;
            font-weight: 600;
            color: #888;
            z-index: 10;
        }

        .btn {
            margin-top: 30px;
            padding: 10px 25px;
            border: none;
            background: #ff4d94;
            color: white;
            border-radius: 25px;
            cursor: pointer;
            font-size: 1rem;
            transition: 0.3s;
        }

        .btn:hover { background: #d63384; transform: scale(1.1); }

        @keyframes bounce {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-20px); }
        }
    </style>
</head>
<body>

    <div id="heart-container"></div>

    <div class="page active" id="page1">
        <h1>Happy Birthday <br> Soumili</h1>
        <button class="btn" onclick="nextPage(2)">Click to See Next ✨</button>
    </div>

    <div class="page" id="page2">
        <h2 style="color: #d63384;">Small Gifts for a Special Friend!</h2>
        <div class="gift-container">
            <span>🍫</span><span>🎂</span><span>🌹</span>
        </div>
        <button class="btn" onclick="nextPage(3)">Read My Message ❤️</button>
    </div>

    <div class="page" id="page3">
        <div class="wish-text">
            "On your special day, I wish you all the happiness in the world. May your year be filled with laughter, success, and beautiful moments. You're an amazing friend, Soumili!"
        </div>
        <button class="btn" onclick="nextPage(1)">Back to Start</button>
    </div>

    <div class="footer">
        With Love, Sashanka Nandi
    </div>

    <script>
        // Page Navigation Logic
        function nextPage(pageNumber) {
            document.querySelectorAll('.page').forEach(page => {
                page.classList.remove('active');
            });
            document.getElementById('page' + pageNumber).classList.add('active');
        }

        // Heart Animation Logic
        function createHeart() {
            const heart = document.createElement('div');
            heart.classList.add('heart');
            heart.innerHTML = '❤️';
            heart.style.left = Math.random() * 100 + 'vw';
            heart.style.animationDuration = (Math.random() * 3 + 2) + 's';
            heart.style.fontSize = (Math.random() * 20 + 10) + 'px';
            document.getElementById('heart-container').appendChild(heart);

            setTimeout(() => {
                heart.remove();
            }, 5000);
        }

        setInterval(createHeart, 300);
    </script>
</body>
</html>
